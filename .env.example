# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:pass@host/netgrid?sslmode=require

# Authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-key-min-32-chars

# Claude API (for report generation + SEO fix content)
ANTHROPIC_API_KEY=sk-ant-...

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=notifications@netgrid.yourdomain.com

# Third-party SEO (optional)
AHREFS_API_KEY=
SEMRUSH_API_KEY=

# Crawler Configuration
CRAWL_DELAY_MS=2000
MAX_CONCURRENT_CRAWLS=5
CRAWL_WINDOW_START=02:00
CRAWL_WINDOW_END=06:00

# Post Verification
POST_CHECK_INTERVAL_HOURS=6

# Invoicing
REMINDER_SCHEDULE_DAYS=1,7,14,30

# Vercel Cron Secret
CRON_SECRET=your-cron-secret
